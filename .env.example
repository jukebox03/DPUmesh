# .env.example — copy to .env and fill in. test-bench.sh sources this and
# refuses to run without it.

# --- DPU (BlueField) over ssh: where the ARM+DPA control plane is built/run ---
DPU_HOST="jukebox@<DPU_IP>"        # ssh target for the DPU
DPU_PASS="<DPU_SUDO_PASSWORD>"     # sudo password on the DPU (start/stop dpumesh_dpu)
DPU_PCI="-p 03:00.0 -r 94:00.0"    # DPU-side PCI args passed to dpumesh_dpu

# --- Local k8s host (where the bench/echo pods run) ---
HOST_PASS="<HOST_SUDO_PASSWORD>"   # sudo password on this host (ctr image import, taskset pinning)
HOST_PCI="94:00.0"                 # host-side PCI address of the DPU function

# --- Optional ---
# DPU_PROJ="DPUmesh"               # dir name of this repo on the DPU (~/$DPU_PROJ); default DPUmesh
